                shipment,
                operation,
                actor_user_id,
                "NOVA_POSHTA_PROVIDER_RESPONSE_AMBIGUOUS",
            )
            return self._reconcile_operation(
                workspace_id,
                shipment,
                connection,
                operation,
                api_key,
                actor_user_id,
            )

