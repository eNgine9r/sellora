            entity_type="Shipment",
            entity_id=shipment.id,
            action="NOVA_POSHTA_RECONCILIATION_REQUIRED",
            new_value={
                "provider": IntegrationProvider.NOVA_POSHTA.value,
                "safe_error": error_code,
                "blind_retry_blocked": True,
