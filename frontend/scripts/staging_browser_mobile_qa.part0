  const refreshToken = login.refresh_token;
  const me = await apiRequest(token, 'GET', '/auth/me');
  const membershipA = (me.memberships || []).find((m) => String(m.workspace_id) === WORKSPACE_A_ID);
  if (!membershipA || membershipA.role !== 'OWNER') throw new Error('OWNER membership for Workspace A not found');
  if (membershipA.workspace_name !== EXPECTED_A_NAME) throw new Error('Workspace A name mismatch');

