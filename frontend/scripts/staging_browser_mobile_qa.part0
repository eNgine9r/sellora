fs.mkdirSync(SCREENSHOT_DIR, { recursive: true });

function redact(value, secrets = []) {
  let text = String(value ?? '');
  for (const secret of secrets) {
    if (secret) text = text.split(secret).join('[REDACTED]');
  }
  text = text.replace(/eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{10,}/g, '[JWT_REDACTED]');
  text = text.replace(/Bearer\s+[A-Za-z0-9._~+\/-]+/gi, 'Bearer [REDACTED]');
  return text.slice(0, 1000);
}

function classifyWorkspaceHeader(value, workspaceBId) {
  if (!value) return 'none';
  if (value === WORKSPACE_A_ID) return 'A';
  if (workspaceBId && value === workspaceBId) return 'B';
  return 'other';
}

function apiUrl(p) {
  const prefix = API.endsWith('/api/v1') ? API : `${API}/api/v1`;
  return `${prefix}${p.startsWith('/') ? p : `/${p}`}`;
}

async function apiRequest(token, method, urlPath, { workspaceId, body } = {}) {
  const headers = {};
  if (token) headers.Authorization = `Bearer ${token}`;
  if (workspaceId) headers['X-Workspace-ID'] = workspaceId;
  if (body !== undefined) headers['Content-Type'] = 'application/json';
  const response = await fetch(apiUrl(urlPath), {
    method,
    headers,
    body: body === undefined ? undefined : JSON.stringify(body),
    signal: AbortSignal.timeout(45000),
  });
  let payload = null;
  const text = await response.text();
  if (text) {
    try { payload = JSON.parse(text); } catch { payload = { text: text.slice(0, 300) }; }
  }
  if (!response.ok) {
    const detail = payload?.detail || payload?.error || `HTTP ${response.status}`;
    throw new Error(`${method} ${urlPath} failed: ${response.status} ${String(detail).slice(0, 200)}`);
  }
  return payload;
}

async function setupFixture() {
  const login = await apiRequest(null, 'POST', '/auth/login', { body: { email: OWNER_EMAIL, password: OWNER_PASSWORD } });
